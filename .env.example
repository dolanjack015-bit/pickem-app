# Postgres connection string. Works great with a free Neon (neon.tech) or
# Vercel Postgres database. Example:
# DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
#
# IMPORTANT for production (Vercel or any serverless host): use Neon's
# POOLED connection string (hostname has "-pooler" in it), and append
# &pgbouncer=true&connect_timeout=15 — without this, Prisma's connection
# handling can conflict with Neon's PgBouncer pooler and cause requests to
# fail with no response body. Not needed for local dev with `next dev`.
# Example: DATABASE_URL="postgresql://user:pass@ep-xyz-pooler.region.aws.neon.tech/db?sslmode=require&pgbouncer=true&connect_timeout=15"
DATABASE_URL=""

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# The public URL of your deployed app, e.g. https://my-pickem.vercel.app
# Use http://localhost:3000 for local dev.
NEXTAUTH_URL="http://localhost:3000"

# Shared secret required to call /api/cron/sync, so random people on the
# internet can't trigger score syncs. Generate any random string.
CRON_SECRET=""
