# Postgres connection string. Works great with a free Neon (neon.tech) or
# Vercel Postgres database. Example:
# DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DATABASE_URL=""

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# The public URL of your deployed app, e.g. https://my-pickem.vercel.app
# Use http://localhost:3000 for local dev.
NEXTAUTH_URL="http://localhost:3000"

# Shared secret required to call /api/cron/sync, so random people on the
# internet can't trigger score syncs. Generate any random string.
CRON_SECRET=""
